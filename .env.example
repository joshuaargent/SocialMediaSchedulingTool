# ============================================
# NextJsTemplate Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================

# ============================================
# SITE CONFIGURATION
# ============================================

# The full URL of your site (required for production)
# Include trailing slash for best results
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# DATABASE (PostgreSQL via Prisma)
# ============================================
# Get a free PostgreSQL database from:
# - Supabase: https://supabase.com (free tier) - RECOMMENDED
# - Neon: https://neon.tech (free tier) - Better for serverless
# - Railway: https://railway.app (free tier)
# - Or self-host with Docker: docker run -d -p 5432:5432 postgres:15

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@host:5432/contenthub?schema=public"

# ============================================
# FILE STORAGE (Free Options for Videos/Images)
# ============================================
# 
# IMPORTANT: Choose ONE storage provider and configure only those variables
# Set STORAGE_PROVIDER to: local, garage, r2, supabase, or b2
#

# Option 0: Local Storage (Development only)
# Stores files in ./uploads folder - not for production!
LOCAL_STORAGE_PATH=./uploads

# Option 1: Garage Storage (Self-hosted - FREE!)
# Run Garage on your Android tablet with SD card
# See setup-garage-android.md for full setup instructions
# Get credentials by running: ./garage key create social-media-tool --bucket videos
GARAGE_ENDPOINT=http://192.168.1.100:3900
GARAGE_ACCESS_KEY=your_access_key_from_garage
GARAGE_SECRET_KEY=your_secret_key_from_garage
GARAGE_BUCKET=videos
GARAGE_PUBLIC_URL=http://192.168.1.100:3900
GARAGE_STORAGE_CAPACITY_GB=256  # Your SD card size (default: 256)

# Option 2: Cloudflare R2 (5GB free - S3 compatible)
# Requires credit card but has free tier
# Get from: https://dash.cloudflare.com/r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=social-media-assets

# Option 3: Supabase Storage (if using Supabase for DB)
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/storage
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_KEY=

# Option 4: Backblaze B2 ($0.006/GB - very cheap, NO credit card!)
# Free tier: 10GB storage, 3x egress free
# Get from: https://www.backblaze.com/b2/cloud-storage.html (no credit card required!)
B2_ACCOUNT_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# ============================================
# STORAGE PROVIDER SELECTION
# ============================================
# Uncomment ONE of these to select your storage provider:
# STORAGE_PROVIDER=local    # Development only
# STORAGE_PROVIDER=garage   # Self-hosted on Android tablet (RECOMMENDED for free)
# STORAGE_PROVIDER=r2       # Cloudflare R2
# STORAGE_PROVIDER=supabase # Supabase Storage
# STORAGE_PROVIDER=b2       # Backblaze B2

# Default (if not set): local storage
STORAGE_PROVIDER=local

# ============================================
# TIKTOK OAUTH
# ============================================
# Get credentials from: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ============================================
# FACEBOOK/INSTAGRAM OAUTH
# ============================================
# Get credentials from: https://developers.facebook.com/
# Create an app at: https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ============================================
# YOUTUBE OAUTH
# ============================================
# Get credentials from: https://console.cloud.google.com/
# Enable YouTube Data API v3 and create OAuth credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ============================================
# GitHub Links (Optional)
# ============================================
GITHUB_USERNAME=joshuaargent
GITHUB_TOKEN=

# ============================================
# STRAVA INTEGRATION (Optional)
# ============================================
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=

# ============================================
# EMAIL & NEWSLETTER (Optional)
# ============================================
BUTTONDOWN_API_KEY=
NEXT_PUBLIC_FORMSPREE_FORM_ID=

# ============================================
# SEO (Optional)
# ============================================
# GOOGLE_VERIFICATION_CODE=your_verification_code

# ============================================
# NEXTAUTH AUTHENTICATION
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here_generate_with_openssl_rand_base64_32

# Your site URL (required for NextAuth)
AUTH_URL=http://localhost:3000

# ============================================
# GOOGLE OAUTH (Optional - for Google sign-in)
# ============================================
# Get credentials from: https://console.cloud.google.com/
# Enable OAuth 2.0 and create credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=