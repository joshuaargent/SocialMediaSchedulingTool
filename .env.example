# ============================================
# NextJsTemplate Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================

# ============================================
# SITE CONFIGURATION
# ============================================

# The full URL of your site (required for production)
# Include trailing slash for best results
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# DATABASE (PostgreSQL via Prisma)
# ============================================
# Get a free PostgreSQL database from:
# - Supabase: https://supabase.com (free tier) - RECOMMENDED
# - Neon: https://neon.tech (free tier) - Better for serverless
# - Railway: https://railway.app (free tier)
# - Or self-host with Docker: docker run -d -p 5432:5432 postgres:15

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@host:5432/contenthub?schema=public"

# ============================================
# FILE STORAGE (Free Options for Videos/Images)
# ============================================
# Option 1: Cloudflare R2 (5GB free - S3 compatible)
# Get from: https://dash.cloudflare.com/r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=social-media-assets

# Option 2: Supabase Storage (if using Supabase for DB)
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/storage
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_KEY=

# Option 3: Backblaze B2 ($0.01/GB - very cheap)
# Get from: https://www.backblaze.com/b2/cloud-storage.html
B2_ACCOUNT_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# Choose your storage provider (uncomment one)
STORAGE_PROVIDER=r2  # Options: r2, supabase, b2, local

# ============================================
# TIKTOK OAUTH
# ============================================
# Get credentials from: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ============================================
# FACEBOOK/INSTAGRAM OAUTH
# ============================================
# Get credentials from: https://developers.facebook.com/
# Create an app at: https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ============================================
# YOUTUBE OAUTH
# ============================================
# Get credentials from: https://console.cloud.google.com/
# Enable YouTube Data API v3 and create OAuth credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ============================================
# GitHub Links (Optional)
# ============================================
GITHUB_USERNAME=joshuaargent
GITHUB_TOKEN=

# ============================================
# STRAVA INTEGRATION (Optional)
# ============================================
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=

# ============================================
# EMAIL & NEWSLETTER (Optional)
# ============================================
BUTTONDOWN_API_KEY=
NEXT_PUBLIC_FORMSPREE_FORM_ID=

# ============================================
# SEO (Optional)
# ============================================
# GOOGLE_VERIFICATION_CODE=your_verification_code

# ============================================
# NEXTAUTH AUTHENTICATION
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here_generate_with_openssl_rand_base64_32

# Your site URL (required for NextAuth)
AUTH_URL=http://localhost:3000

# ============================================
# GOOGLE OAUTH (Optional - for Google sign-in)
# ============================================
# Get credentials from: https://console.cloud.google.com/
# Enable OAuth 2.0 and create credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=